ers, year)\nVALUES (2, 'Duolingo', 'Pittsburgh \uD83D\uDC1D', 2011);\n\nINSERT INTO companies (id, name, headquarters, year)\nVALUES (3, 'BeReal', 'Paris \uD83C\uDDEB\uD83C\uDDF7', 2020);\n\nINSERT INTO companies (id, name, headquarters, year)\nVALUES (4, 'Codedex', 'New York \uD83D\uDDFD', 2022);\n"}function createCompaniesTableWithDataIncludingWebsite(){return"\nCREATE TABLE companies (\n    id INTEGER,\n    name TEXT,\n    headquarters TEXT,\n    year INTEGER,\n    website TEXT\n    );\n\nINSERT INTO companies (id, name, headquarters, year, website)\nVALUES (1, 'Twitter', 'San Francisco \uD83C\uDF01', 2006, 'twitter.com');\n\nINSERT INTO companies (id, name, headquarters, year, website)\nVALUES (2, 'Duolingo', 'Pittsburgh \uD83D\uDC1D', 2011, 'duolingo.com');\n\nINSERT INTO companies (id, name, headquarters, year, website)\nVALUES (3, 'BeReal', 'Paris \uD83C\uDDEB\uD83C\uDDF7', 2020, 'bereal.com');\n\nINSERT INTO companies (id, name, headquarters, year, website)\nVALUES (4, 'Codedex', 'New York \uD83D\uDDFD', 2022, 'codedex.io');\n"}function createAuthorsAndBooksTableWithData(){return"\nCREATE TABLE authors (\n    id INTEGER,\n    name TEXT,\n    born INTEGER,\n    books INTEGER\n);\n\nINSERT INTO authors (id, name, born, books)\nVALUES (1, 'George R. R. Martin', 1948, 13);\nINSERT INTO authors (id, name, born, books)\nVALUES (2, 'Patti Smith', 1946, 10);\nINSERT INTO authors (id, name, born, books)\nVALUES (3, 'Sally Rooney', 1991, 9);\nINSERT INTO authors (id, name, born, books)\nVALUES (4, 'Haruki Murakami', 1949, 18);\nINSERT INTO authors (id, name, born, books)\nVALUES (5, 'J. R. R. Tolkien', 1892, 12);\nINSERT INTO authors (id, name, born, books)\nVALUES (6, 'Michelle Zauner', 1989, 1);\nINSERT INTO authors (id, name, born, books)\nVALUES (7, 'Ellen Ullman', 1949, 6);\n\nCREATE TABLE books (\n    book_id INTEGER,\n    title TEXT,\n    author_id INTEGER,\n    year INTEGER,\n    fictional BOOLEAN,\n    goodreads REAL\n);\n\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1001, 'A Game of Thrones', 1, 1991, TRUE, 4.45);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1002, 'Just Kids', 2, 2010, FALSE, 4.21);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1003, 'Life in Code', 7, 2017, FALSE, 3.97);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1004, 'The Prophet', NULL, 1923, TRUE, 4.23);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1005, 'The Mom Test', NULL, 2013, FALSE, 4.37);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1006, 'Milk and Honey', NULL, 2014, FALSE, 3.97);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1007, 'High Output Management', NULL, 1983, FALSE, 4.30);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1008, 'Networks of New York', NULL, 2016, FALSE, 3.80);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1009, 'Born a Crime', NULL, 2016, FALSE, 4.49);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1010, 'Normal People', 3, 2018, TRUE, 3.81);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1011, 'Kafka on the Shore', 4, 2002, TRUE, 4.12);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1012, 'The Hobbit', 5, 1937, TRUE, 4.29);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1013, 'Crying in H Mart', 6, 2021, FALSE, 4.25);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1014, 'Why We Sleep', NULL, 2017, FALSE, 4.38);\n"}function createAllDb4MasterTableWithData(){return"\nCREATE TABLE directors (\n    id INTEGER,\n    name TEXT,\n    country TEXT,\n    style TEXT\n);\n\nINSERT INTO directors (id, name, country, style)\nVALUES (1, 'Quentin Tarantino', 'USA', 'Stylized violence, nonlinear, pop culture');\nINSERT INTO directors (id, name, country, style)\nVALUES (2, 'Wes Anderson', 'USA', 'Symmetrical, vintage colors, quirky, indie');\nINSERT INTO directors (id, name, country, style)\nVALUES (3, 'Greta Gerwig', 'USA', 'Coming-of-age, character-driven');\nINSERT INTO directors (id, name, country, style)\nVALUES (4, 'Hayao Miyazaki', 'Japan', 'Animation, fantasy, nature, hand-drawn');\nINSERT INTO directors (id, name, country, style)\nVALUES (5, 'Christopher Nolan', 'UK', 'High-concept, cerebral, epic');\nINSERT INTO directors (id, name, country, style)\nVALUES (6, 'Bong Joon Ho', 'South Korea', 'Social commentary, dark comedy');\nINSERT INTO directors (id, name, country, style)\nVALUES (7, 'Stanley Kubrick', 'USA', 'One-point perspective, long takes, details');\nINSERT INTO directors (id, name, country, style)\nVALUES (8, 'Wong Kar-wai', 'China', 'Neon, dream-like, handheld camera, love');\n\n\nCREATE TABLE movies (\n    id INTEGER,\n    name TEXT,\n    year INTEGER,\n    director TEXT,\n    genre TEXT,\n    imdb REAL\n);\n\nINSERT INTO movies (id, name, year, director, genre, imdb)\nVALUES (1, 'Pulp Fiction', 1994, 'Quentin Tarantino', 'Crime, Drama', 8.9);\nINSERT INTO movies (id, name, year, director, genre, imdb)\nVALUES (2, 'The Royal Tenenbaums', 2001, 'Wes Anderson', 'Comedy Drama', 7.6);\nINSERT INTO movies (id, name, year, director, genre, imdb)\nVALUES (3, 'Fantastic Mr. Fox', 2009, 'Wes Anderson', 'Animation, Comedy', 7.9);\nINSERT INTO movies (id, name, year, director, genre, imdb)\nVALUES (4, 'Barbie', 2023, 'Greta Gerwig', 'Comedy, Fantasy', 6.8);\nINSERT INTO movies (id, name, year, director, genre, imdb)\nVALUES (5, 'Lady Bird', 2017, 'Greta Gerwig', 'Comedy, Indie', 7.4);\nINSERT INTO movies (id, name, year, director, genre, imdb)\nVALUES (6, 'Spirited Away', 2001, 'Hayao Miyazaki', 'Animation, Fantasy', 8.6);\nINSERT INTO movies (id, name, year, director, genre, imdb)\nVALUES (7, 'Howl’s Moving Castle', 2004, 'Hayao Miyazaki', 'Animation, Fantasy', 8.2);\nINSERT INTO movies (id, name, year, director, genre, imdb)\nVALUES (8, 'Parasite', 2019, 'Bong Joon Ho', 'Drama, Thriller', 8.5);\nINSERT INTO movies (id, name, year, director, genre, imdb)\nVALUES (9, 'Anora', 2024, 'Sean Baker', 'Comedy, Drama', 7.5);\n\nCREATE TABLE authors (\n    id INTEGER,\n    name TEXT,\n    born INTEGER,\n    books INTEGER\n);\n\nINSERT INTO authors (id, name, born, books)\nVALUES (1, 'George R. R. Martin', 1948, 13);\nINSERT INTO authors (id, name, born, books)\nVALUES (2, 'Patti Smith', 1946, 10);\nINSERT INTO authors (id, name, born, books)\nVALUES (3, 'Sally Rooney', 1991, 9);\nINSERT INTO authors (id, name, born, books)\nVALUES (4, 'Haruki Murakami', 1949, 18);\nINSERT INTO authors (id, name, born, books)\nVALUES (5, 'J. R. R. Tolkien', 1892, 12);\nINSERT INTO authors (id, name, born, books)\nVALUES (6, 'Michelle Zauner', 1989, 1);\nINSERT INTO authors (id, name, born, books)\nVALUES (7, 'Ellen Ullman', 1949, 6);\n\nCREATE TABLE books (\n    book_id INTEGER,\n    title TEXT,\n    author_id INTEGER,\n    year INTEGER,\n    fictional BOOLEAN,\n    goodreads REAL\n);\n\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1001, 'A Game of Thrones', 1, 1991, TRUE, 4.45);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1002, 'Just Kids', 2, 2010, FALSE, 4.21);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1003, 'Life in Code', 7, 2017, FALSE, 3.97);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1004, 'The Prophet', NULL, 1923, TRUE, 4.23);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1005, 'The Mom Test', NULL, 2013, FALSE, 4.37);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1006, 'Milk and Honey', NULL, 2014, FALSE, 3.97);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1007, 'High Output Management', NULL, 1983, FALSE, 4.30);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1008, 'Networks of New York', NULL, 2016, FALSE, 3.80);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1009, 'Born a Crime', NULL, 2016, FALSE, 4.49);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1010, 'Normal People', 3, 2018, TRUE, 3.81);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1011, 'Kafka on the Shore', 4, 2002, TRUE, 4.12);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1012, 'The Hobbit', 5, 1937, TRUE, 4.29);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1013, 'Crying in H Mart', 6, 2021, FALSE, 4.25);\nINSERT INTO books (book_id, title, author_id, year, fictional, goodreads)\nVALUES (1014, 'Why We Sleep', NULL, 2017, FALSE, 4.38);\n\n\nCREATE TABLE orders (\nid INTEGER,\ndate TEXT,\ncustomer TEXT,\ncustomer_id INTEGER,\nfulfilled BOOLEAN,\nitem_id INTEGER\n);\n\nINSERT INTO orders (id, date, customer, customer_id, fulfilled, item_id)\nVALUES (1001, '2025-05-10', 'Sonny Li', 9, TRUE, 1);\nINSERT INTO orders (id, date, customer, customer_id, fulfilled, item_id)\nVALUES (1002, '2025-05-11', 'Tea', 8, TRUE, 1);\nINSERT INTO orders (id, date, customer, customer_id, fulfilled, item_id)\nVALUES (1003, '2025-05-17', 'TeeJay', 4, TRUE, 3);\nINSERT INTO orders (id, date, customer, customer_id, fulfilled, item_id)\nVALUES (1004, '2025-05-19', 'Intelagense', 2, TRUE, 1);\nINSERT INTO orders (id, date, customer, customer_id, fulfilled, item_id)\nVALUES (1005, '2025-05-20', 'Pikacodes', 7, TRUE, 3);\nINSERT INTO orders (id, date, customer, customer_id, fulfilled, item_id)\nVALUES (1006, '2025-05-20', 'Deepister', 6, TRUE, 5);\nINSERT INTO orders (id