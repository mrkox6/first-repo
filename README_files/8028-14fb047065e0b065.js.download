rime Drama', 'HBO', 1999, 6, 92),\n(7, 'Game of Thrones', 'Action Fantasy', 'HBO', 2011, 8, 89),\n(8, 'High Maintenance', 'Comedy Drama', 'HBO', 2016, 4, 98),\n(9, 'Euphoria', 'Teen Drama', 'HBO', 2019, 2, 88),\n(10, 'How To with John Wilson', 'Comedy', 'HBO', 2020, 3, 100),\n(11, 'Band of Brothers', 'War Drama', 'HBO', 2021, 1, 97),\n(12, 'Insecure', 'Comedy Drama', 'HBO', 2016, 5, 97),\n(13, 'Boardwalk Empire', 'Period Drama', 'HBO', 2010, 5, 92),\n(14, 'Sex and the City', 'Drama', 'HBO', 1998, 6, 70),\n(15, 'Squid Game', 'Survival Thriller', 'Netflix', 2021, 2, 95),\n(16, 'Master of None', 'Comedy Drama', 'Netflix', 2015, 3, 94),\n(17, 'Alone', 'Reality TV Survival', 'Netflix', 2015, 10, 93),\n(18, 'Black Mirror', 'Science Fiction', 'Netflix', 2011, 6, 83),\n(19, 'The Queen''s Gambit', 'Period Drama', 'Netflix', 2020, 1, 96),\n(20, 'Ugly Delicious', 'Cooking Travel', 'Netflix', 2018, 2, 100),\n(21, 'Single''s Inferno', 'Reality TV Dating', 'Netflix', 2021, 3, 82),\n(22, 'Peaky Blinders', 'Period Drama', 'Netflix', 2013, 6, 93),\n(23, 'High Score', 'Documentary', 'Netflix', 2020, 1, 78),\n(24, 'The Last Dance', 'Documentary', 'Netflix', 2020, 1, 97),\n(25, 'Wednesday', 'Black Comedy', 'Netflix', 2022, 1, 73),\n(26, 'House of Cards', 'Political Drama', 'Netflix', 2013, 6, 77),\n(27, 'Narcos', 'Crime Drama', 'Netflix', 2015, 3, 89),\n(28, 'Orange is the New Black', 'Drama', 'Netflix', 2013, 7, 90),\n(29, 'Love is Blind', 'Reality TV Dating', 'Netflix', 2020, 6, 57),\n(30, 'Love', 'Romance', 'Netflix', 2016, 3, 94),\n(31, 'Stranger Things', 'Horror', 'Netflix', 2016, 4, 92),\n(32, 'Breaking Bad', 'Drama', 'Netflix', 2008, 5, 96),\n(33, 'Better Call Saul', 'Drama', 'Netflix', 2015, 6, 98),\n(34, 'Avatar: The Last Airbender', 'Action', 'Netflix', 2005, 3, 100),\n(35, 'Bridgerton', 'Romance', 'Netflix', 2020, 3, 82),\n(36, 'Broad City', 'Sitcom', 'Hulu', 2014, 5, 99),\n(37, 'The Bear', 'Drama', 'Hulu', 2022, 2, 99),\n(38, 'Wu-Tang: An American Saga', 'Drama', 'Hulu', 2019, 3, 84),\n(39, 'Mr. Robot', 'Drama', 'Amazon', 2015, 4, 94),\n(40, 'Halt and Catch Fire', 'Drama', 'Pluto TV', 2014, 4, 90),\n(41, 'The IT Crowd', 'Sitcom', 'Pluto TV', 2006, 4, 85),\n(42, 'Nathan For You', 'Reality', 'Pluto TV', 2013, 6, 97),\n(43, 'Mad Men', 'Drama', 'AMC+', 2007, 7, 94),\n(44, 'Walking Dead', 'Drama', 'AMC+', 2010, 11, 79),\n(45, 'The Mandalorian', 'Action', 'Disney+', 2019, 3, 90),\n(46, 'Jujutsu Kaisen', 'Anime', 'Crunchyroll', 2020, 2, 92),\n(47, 'One Piece', 'Anime', 'Crunchyroll', 1999, 21, 94),\n(48, 'My Hero Academia', 'Anime', 'Crunchyroll', 2016, 7, 100),\n(49, 'Naruto Shippuden', 'Anime', 'Crunchyroll', 2007, 21, 93),\n(50, 'Bleach', 'Anime', 'Crunchyroll', 2004, 16, 71);\n\n"}function createPlaylistTable(){return"\nCREATE TABLE playlist (\n    title VARCHAR(255),\n    artist VARCHAR(255),\n    album VARCHAR(255),\n    year INT,\n    genre VARCHAR(100),\n    plays BIGINT,\n    duration INT\n);\n\nINSERT INTO playlist (title, artist, album, year, genre, plays, duration) VALUES ('Soft Power', 'LVL UP', 'Hoodwink''d', 2014, 'Lo-fi', 777105, 174);\nINSERT INTO playlist (title, artist, album, year, genre, plays, duration) VALUES ('Spirit Was', 'LVL UP', 'Return to Love', 2016, 'Lo-fi', 549052, 251);\nINSERT INTO playlist (title, artist, album, year, genre, plays, duration) VALUES ('rangeover', 'Porches', 'Ricky Music', 2020, 'Indie', 7191816, 135);\nINSERT INTO playlist (title, artist, album, year, genre, plays, duration) VALUES ('Xanny Bar', 'Porches', 'Slow Dance in the Cosmos', 2013, 'Indie', 851154, 191);\nINSERT INTO playlist (title, artist, album, year, genre, plays, duration) VALUES ('You Swan, Go On', 'Mount Eerie', 'Lost Wisdom', 2008, 'Folk', 3817153, 92);\nINSERT INTO playlist (title, artist, album, year, genre, plays, duration) VALUES ('Great Ghosts', 'Mount Eerie', 'Dawn', 2008, 'Folk', 570540, 194);\nINSERT INTO playlist (title, artist, album, year, genre, plays, duration) VALUES ('I Felt Your Shape', 'The Microphones', 'The